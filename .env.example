# =============================================================
# ArcVault AI Triage Pipeline - Environment Configuration
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your .env file to version control.
# =============================================================

# --- LLM Provider Selection ---
# Options: openai, deepseek
LLM_PROVIDER=openai

# --- OpenAI Configuration ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5.4
# Alternative models: gpt-4o, gpt-4-turbo, gpt-3.5-turbo

# --- DeepSeek Configuration ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat
# Alternative models: deepseek-reasoner

# --- n8n Configuration ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/arcvault-intake
N8N_PORT=5678

# --- Google Sheets Configuration ---
GOOGLE_SHEETS_ID=your-google-sheet-id-here
PROCESSED_SHEET_NAME=Processed Requests
ESCALATION_SHEET_NAME=Escalation Queue
